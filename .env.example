# EmpleoViral AI — Variables de Entorno
# Copia este archivo a .env.local y llena los valores

# API de Anthropic (Claude) para generacion de texto con IA
ANTHROPIC_API_KEY=sk-ant-xxxxx

# API de Google AI (Gemini / Nanobanana) para generacion de imagenes
GOOGLE_AI_API_KEY=AIzaSyxxxxx

# API de Google Veo 3.1 para generacion de video
GOOGLE_VEO_API_KEY=AIzaSyxxxxx

# URL base de tu sitio (para CTAs y enlaces)
NEXT_PUBLIC_SITE_URL=https://tu-sitio.com
